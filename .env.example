# Slack Bot Token (requires files:write + chat:write scopes)
SLACK_BOT_TOKEN=xoxb-your-token-here
# Slack Channel ID (not channel name)
SLACK_CHANNEL=C0123456789
# crypto-research-agent (dexter) のリポジトリパス
# 未設定時は ~/Documents/workspace/boxter/crypto-research-agent (Mac default) を参照
# VPS 例: /opt/bexter/dexter
CRYPTO_RESEARCH_AGENT_DIR=
